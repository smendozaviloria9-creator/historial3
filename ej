# Inicializamos los contadores en cero
agotados = 0
stock_bajo = 0
stock_normal = 0

# Usamos un ciclo para pedir 10 productos
for i in range(1, 11):
    print(f"--- Producto {i} ---")
    nombre = input("Ingrese el nombre del producto: ")
    cantidad = int(input(f"Ingrese la cantidad disponible de {nombre}: "))

    # Clasificación según los rangos solicitados
    if cantidad == 0:
        print("Estado: Agotado")
        agotados += 1
    elif 1 <= cantidad <= 5:
        print("Estado: Stock bajo")
        stock_bajo += 1
    elif cantidad >= 6:
        print("Estado: Stock normal")
        stock_normal += 1
    
    print("-" * 20)

# Resumen final de resultados
print("\n=== RESUMEN DE INVENTARIO CRÍTICO ===")
print(f"Productos agotados: {agotados}")
print(f"Productos con stock bajo: {stock_bajo}")
print(f"Productos con stock normal: {stock_normal}")
